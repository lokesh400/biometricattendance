<div id="studentModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
  <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-md w-full mx-4">
    <h3 class="text-2xl font-bold text-emerald-600 mb-4">👤 Add Student</h3>
    <form id="studentForm" class="space-y-4">
      <input type="hidden" id="studentClassId">
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Roll Number</label>
        <input 
          type="text" 
          id="studentRoll" 
          placeholder="e.g., CS001"
          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none"
          required
        >
      </div>
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Full Name</label>
        <input 
          type="text" 
          id="studentName" 
          placeholder="e.g., John Doe"
          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none"
          required
        >
      </div>
      <div class="flex gap-3">
        <button 
          type="button"
          class="flex-1 px-4 py-3 bg-slate-300 hover:bg-slate-400 text-slate-900 font-semibold rounded-lg transition"
          onclick="closeModal('studentModal')"
        >
          Cancel
        </button>
        <button 
          type="submit"
          class="flex-1 px-4 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-lg transition"
        >
          Enroll Student
        </button>
      </div>
    </form>
  </div>
</div>

<div id="bulkUploadModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
  <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-lg w-full mx-4">
    <h3 class="text-2xl font-bold text-brand-600 mb-4">📄 Bulk Upload Students</h3>
    <p class="mb-4 text-sm text-slate-600">Upload an .xlsx file with <strong>Roll Number</strong> and <strong>Name</strong> in the first sheet header row.</p>
    <form id="bulkUploadForm" class="space-y-4">
      <input type="hidden" id="bulkUploadClassId">
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Excel Sheet (.xlsx)</label>
        <input
          type="file"
          id="bulkUploadFile"
          accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none bg-white"
          required
        >
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
        <p class="font-semibold text-slate-900 mb-1">Expected columns</p>
        <p>Use headers like Roll Number, Roll No, Roll, or Name / Full Name / Student Name.</p>
        <p class="mt-2">Duplicate roll numbers in the sheet or existing class records will be skipped.</p>
      </div>
      <div class="rounded-xl border border-brand-200 bg-brand-50 p-4">
        <div class="mb-3 flex items-center justify-between gap-3">
          <p class="text-sm font-bold text-brand-700">Demo sheet preview</p>
          <span class="rounded-full bg-white px-2.5 py-1 text-[11px] font-semibold text-brand-700 border border-brand-200">Reference only</span>
        </div>
        <div class="overflow-hidden rounded-lg border border-brand-200 bg-white shadow-sm">
          <table class="min-w-full text-left text-xs">
            <thead class="bg-brand-600 text-white">
              <tr>
                <th class="px-3 py-2 font-semibold">Roll Number</th>
                <th class="px-3 py-2 font-semibold">Name</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              <tr>
                <td class="px-3 py-2 font-mono text-slate-700">CS001</td>
                <td class="px-3 py-2 text-slate-700">Asha Kumar</td>
              </tr>
              <tr>
                <td class="px-3 py-2 font-mono text-slate-700">CS002</td>
                <td class="px-3 py-2 text-slate-700">Rahul Singh</td>
              </tr>
              <tr>
                <td class="px-3 py-2 font-mono text-slate-700">CS003</td>
                <td class="px-3 py-2 text-slate-700">Priya Patel</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div id="bulkUploadStatus" class="text-sm font-medium text-slate-600"></div>
      <div class="flex gap-3">
        <button
          type="button"
          class="flex-1 px-4 py-3 bg-slate-300 hover:bg-slate-400 text-slate-900 font-semibold rounded-lg transition"
          onclick="closeModal('bulkUploadModal')"
        >
          Cancel
        </button>
        <button
          type="submit"
          class="flex-1 px-4 py-3 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-lg transition"
        >
          Upload Students
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Page Header & Action -->
<section class="mb-6">
  <% const classTabHref = activeClassId ? `/class/${activeClassId}` : '/'; %>
  <% const attendanceTabHref = activeClassId ? `/class/${activeClassId}/attendance` : '/'; %>
  <div class="mb-4 inline-flex rounded-xl border border-slate-300 bg-slate-50 p-1">
    <a href="<%= classTabHref %>" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-bold text-white shadow-sm">Students</a>
    <a href="<%= attendanceTabHref %>" class="rounded-lg px-4 py-2 text-sm font-bold text-slate-700 transition hover:bg-white">Attendance</a>
  </div>

  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-3xl font-extrabold text-slate-950">
        <% if (activeClassName) { %>
          <%= activeClassName %>
        <% } else { %>
          Classes
        <% } %>
      </h2>
      <p class="text-slate-600 mt-1">Manage students and their fingerprint enrollment</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <% if (currentUser && activeClassId) { %>
        <button 
          class="px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-lg shadow-md transition"
          onclick="openStudentModal('<%= activeClassId %>')"
        >
          👤 Add Student
        </button>
        <button
          class="px-6 py-3 bg-brand-600 hover:bg-brand-700 text-white font-bold rounded-lg shadow-md transition"
          onclick="openBulkUploadModal('<%= activeClassId %>')"
        >
          📄 Bulk Upload
        </button>
      <% } else if (!currentUser) { %>
        <a href="/login?next=<%= encodeURIComponent('/class/' + (activeClassId || '')) %>" class="inline-flex items-center px-6 py-3 bg-slate-700 hover:bg-slate-800 text-white font-bold rounded-lg shadow-md transition">Admin Login</a>
      <% } %>
    </div>
  </div>
</section>

<!-- Quick Stats Cards (if active class) -->
<% if (activeClassId && students.length > 0) { %>
  <section class="grid gap-4 sm:grid-cols-3 mb-6">
    <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
      <p class="text-xs font-bold uppercase tracking-widest text-slate-600">Total Students</p>
      <p class="mt-3 text-4xl font-extrabold text-slate-950"><%= students.length %></p>
    </article>
    <article class="rounded-2xl border border-emerald-200 bg-emerald-50 p-6 shadow-soft">
      <p class="text-xs font-bold uppercase tracking-widest text-emerald-700">Enrolled (Fingerprint)</p>
      <p class="mt-3 text-4xl font-extrabold text-emerald-600"><%= students.filter(s => s.fingerprintTemplateHex && String(s.fingerprintTemplateHex).trim()).length %></p>
    </article>
    <article class="rounded-2xl border border-orange-200 bg-orange-50 p-6 shadow-soft">
      <p class="text-xs font-bold uppercase tracking-widest text-orange-700">Pending Enrollment</p>
      <p class="mt-3 text-4xl font-extrabold text-orange-600"><%= students.filter(s => !(s.fingerprintTemplateHex && String(s.fingerprintTemplateHex).trim())).length %></p>
    </article>
  </section>
<% } %>

<!-- Empty State -->
<% if (!activeClassId || !students.length) { %>
  <section class="rounded-2xl border border-slate-200 bg-white p-12 shadow-soft text-center">
    <p class="text-slate-600 text-lg">
      <% if (!activeClassId && classes.length === 0) { %>
        No classes created yet.
        <% if (currentUser) { %>
          <a href="#" onclick="document.querySelector('[data-open-global-class-modal=\"true\"]')?.click(); return false;" class="text-brand-600 font-bold hover:underline">Create your first class</a>
        <% } else { %>
          <a href="/login?next=/admin" class="text-brand-600 font-bold hover:underline">Login to create your first class</a>
        <% } %>
        to get started.
      <% } else if (!students.length && activeClassId) { %>
        No students in this class yet.
        <% if (currentUser) { %>
          <a href="#" onclick="openStudentModal('<%= activeClassId %>'); return false;" class="text-emerald-600 font-bold hover:underline">Add the first student</a>
        <% } else { %>
          <a href="/login?next=<%= encodeURIComponent('/class/' + activeClassId) %>" class="text-emerald-600 font-bold hover:underline">Login to add the first student</a>
        <% } %>
        to begin enrollment.
      <% } %>
    </p>
  </section>
<% } %>

<!-- Students List Table -->
<% if (activeClassId && students.length > 0) { %>
  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft mb-6">
    <div class="mb-5">
      <p class="text-xs font-bold uppercase tracking-widest text-slate-600">Roster</p>
      <h3 class="mt-2 text-lg font-extrabold text-slate-950">Students in <%= activeClassName %></h3>
    </div>

    <div class="overflow-x-auto rounded-xl border border-slate-300">
      <table class="min-w-full text-sm">
        <thead class="bg-gradient-to-r from-slate-50 to-slate-100">
          <tr>
            <th class="px-4 py-3 text-left font-semibold text-slate-700">Roll</th>
            <th class="px-4 py-3 text-left font-semibold text-slate-700">Name</th>
            <th class="px-4 py-3 text-left font-semibold text-slate-700">Fingerprint ID</th>
            <th class="px-4 py-3 text-left font-semibold text-slate-700">Status</th>
            <th class="px-4 py-3 text-left font-semibold text-slate-700">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <% students.forEach(student => { %>
            <tr class="hover:bg-slate-50 transition">
              <td class="px-4 py-3 font-medium text-slate-900"><%= student.rollNumber %></td>
              <td class="px-4 py-3 text-slate-700"><%= student.name %></td>
              <td class="px-4 py-3 font-mono text-xs text-brand-600">
                <% if (student.fingerprintId) { %>
                  ID <%= student.fingerprintId %>
                <% } else { %>
                  <span class="text-slate-500">Not assigned</span>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <% if (student.fingerprintTemplateHex && String(student.fingerprintTemplateHex).trim()) { %>
                  <span class="inline-flex rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700">✓ Enrolled</span>
                <% } else { %>
                  <span class="inline-flex rounded-full bg-orange-100 px-2.5 py-1 text-xs font-semibold text-orange-700">⏳ Pending</span>
                <% } %>
              </td>
              <td class="px-4 py-3 space-x-2">
                <% if (student.fingerprintTemplateHex && String(student.fingerprintTemplateHex).trim()) { %>
                  <button 
                    class="px-3 py-1 text-xs font-semibold bg-blue-100 text-blue-700 rounded hover:bg-blue-200 transition"
                    onclick="reenroll('<%= student._id %>', '<%= student.name %>')"
                  >
                    🔄 Re-enroll
                  </button>
                <% } else { %>
                  <button 
                    class="px-3 py-1 text-xs font-semibold bg-emerald-100 text-emerald-700 rounded hover:bg-emerald-200 transition"
                    onclick="reenroll('<%= student._id %>', '<%= student.name %>')"
                  >
                    👆 Enroll
                  </button>
                <% } %>
                <button 
                  class="px-3 py-1 text-xs font-semibold bg-red-100 text-red-700 rounded hover:bg-red-200 transition"
                  onclick="deleteStudent('<%= student._id %>', '<%= student.name %>')"
                >
                  🗑 Delete
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <% if (activeClassId) { %>
    <section class="rounded-2xl border border-red-200 bg-red-50 p-6 shadow-soft">
      <button 
        class="w-full px-4 py-3 bg-red-600 hover:bg-red-700 text-white font-bold rounded transition"
        onclick="deleteWholeClass('<%= activeClassId %>', '<%= activeClassName %>')"
      >
        ⚠️ Delete Entire Class (<%= students.length %> students)
      </button>
    </section>
  <% } %>
<% } %>

<section class="rounded-2xl border border-indigo-200 bg-indigo-50 p-5 shadow-soft mb-6" id="liveEnrollmentSection">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="text-xs font-bold uppercase tracking-widest text-indigo-700">Live Enrollment Sync</p>
      <h3 class="mt-1 text-lg font-extrabold text-slate-950">ESP32 Enrollment Status</h3>
    </div>
    <span id="liveSyncBadge" class="inline-flex rounded-full bg-slate-200 px-3 py-1 text-xs font-semibold text-slate-700">Checking...</span>
  </div>
  <p id="liveSyncText" class="mt-3 text-sm font-medium text-slate-700">Waiting for latest updates...</p>
</section>

<div id="uiDialogModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-[70] p-4">
  <div class="w-full max-w-lg rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl">
    <h3 id="uiDialogTitle" class="text-xl font-extrabold text-slate-950">Action</h3>
    <p id="uiDialogMessage" class="mt-2 text-sm text-slate-700"></p>

    <div id="uiDialogChecklist" class="mt-4 hidden space-y-2 rounded-xl border border-rose-200 bg-rose-50 p-3">
      <label class="flex items-center gap-2 text-sm text-rose-900">
        <input type="checkbox" class="ui-triple-check h-4 w-4 accent-rose-600" />
        I understand this action is permanent.
      </label>
      <label class="flex items-center gap-2 text-sm text-rose-900">
        <input type="checkbox" class="ui-triple-check h-4 w-4 accent-rose-600" />
        I understand related records may be removed from sensor queue.
      </label>
      <label class="flex items-center gap-2 text-sm text-rose-900">
        <input type="checkbox" class="ui-triple-check h-4 w-4 accent-rose-600" />
        I want to continue.
      </label>
    </div>

    <div class="mt-6 flex gap-3">
      <button id="uiDialogCancel" class="flex-1 rounded-lg bg-slate-200 px-4 py-2.5 text-sm font-bold text-slate-800 hover:bg-slate-300">Cancel</button>
      <button id="uiDialogConfirm" class="flex-1 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-bold text-white hover:bg-brand-700">Continue</button>
    </div>
  </div>
</div>

<div id="uiNoticeModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-[72] p-4">
  <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl">
    <h3 id="uiNoticeTitle" class="text-xl font-extrabold text-slate-950">Notice</h3>
    <p id="uiNoticeMessage" class="mt-2 text-sm text-slate-700"></p>
    <button id="uiNoticeClose" class="mt-5 w-full rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-bold text-white hover:bg-brand-700">OK</button>
  </div>
</div>

<script>
let currentDialogResolver = null;
let enrollmentPollTimer = null;

function openModal(id) {
  document.getElementById(id)?.classList.remove('hidden');
}

function closeModal(id) {
  document.getElementById(id)?.classList.add('hidden');
}

function openBulkUploadModal(classId) {
  const classField = document.getElementById('bulkUploadClassId');
  const fileInput = document.getElementById('bulkUploadFile');
  const statusEl = document.getElementById('bulkUploadStatus');

  if (classField) {
    classField.value = classId;
  }
  if (fileInput) {
    fileInput.value = '';
  }
  if (statusEl) {
    statusEl.textContent = 'Select an Excel file to import students into this class.';
  }

  openModal('bulkUploadModal');
}

function arrayBufferToBase64(buffer) {
  const bytes = new Uint8Array(buffer);
  const chunkSize = 0x8000;
  let binary = '';

  for (let i = 0; i < bytes.length; i += chunkSize) {
    const chunk = bytes.subarray(i, i + chunkSize);
    binary += String.fromCharCode.apply(null, chunk);
  }

  return btoa(binary);
}

function showNotice(title, message) {
  return new Promise((resolve) => {
    const titleEl = document.getElementById('uiNoticeTitle');
    const messageEl = document.getElementById('uiNoticeMessage');
    const closeBtn = document.getElementById('uiNoticeClose');

    titleEl.textContent = title;
    messageEl.textContent = message;
    openModal('uiNoticeModal');

    const onClose = () => {
      closeBtn.removeEventListener('click', onClose);
      closeModal('uiNoticeModal');
      resolve();
    };
    closeBtn.addEventListener('click', onClose);
  });
}

function showConfirmDialog({ title, message, confirmText = 'Continue', danger = false, requireTriple = false }) {
  return new Promise((resolve) => {
    const titleEl = document.getElementById('uiDialogTitle');
    const messageEl = document.getElementById('uiDialogMessage');
    const checklistEl = document.getElementById('uiDialogChecklist');
    const cancelBtn = document.getElementById('uiDialogCancel');
    const confirmBtn = document.getElementById('uiDialogConfirm');
    const checks = Array.from(document.querySelectorAll('.ui-triple-check'));

    titleEl.textContent = title;
    messageEl.textContent = message;
    confirmBtn.textContent = confirmText;
    confirmBtn.className = `flex-1 rounded-lg px-4 py-2.5 text-sm font-bold text-white ${danger ? 'bg-rose-600 hover:bg-rose-700' : 'bg-brand-600 hover:bg-brand-700'}`;

    checks.forEach((c) => { c.checked = false; });
    checklistEl.classList.toggle('hidden', !requireTriple);
    confirmBtn.disabled = Boolean(requireTriple);
    confirmBtn.classList.toggle('opacity-50', Boolean(requireTriple));

    const refreshConfirmState = () => {
      if (!requireTriple) {
        confirmBtn.disabled = false;
        confirmBtn.classList.remove('opacity-50');
        return;
      }
      const allChecked = checks.every((c) => c.checked);
      confirmBtn.disabled = !allChecked;
      confirmBtn.classList.toggle('opacity-50', !allChecked);
    };

    checks.forEach((c) => c.addEventListener('change', refreshConfirmState));

    const cleanup = () => {
      checks.forEach((c) => c.removeEventListener('change', refreshConfirmState));
      cancelBtn.removeEventListener('click', onCancel);
      confirmBtn.removeEventListener('click', onConfirm);
      closeModal('uiDialogModal');
      currentDialogResolver = null;
    };

    const onCancel = () => {
      cleanup();
      resolve(false);
    };

    const onConfirm = () => {
      cleanup();
      resolve(true);
    };

    currentDialogResolver = resolve;
    cancelBtn.addEventListener('click', onCancel);
    confirmBtn.addEventListener('click', onConfirm);
    openModal('uiDialogModal');
    refreshConfirmState();
  });
}

async function fetchJson(url, options = {}) {
  const res = await fetch(url, options);
  const contentType = String(res.headers.get('content-type') || '');
  if (contentType.includes('application/json')) {
    const data = await res.json();
    return { ok: res.ok, data, status: res.status };
  }
  const text = await res.text();
  return {
    ok: false,
    status: res.status,
    data: {
      ok: false,
      message: res.status === 401 ? 'Admin login required. Please login again.' : (text || 'Unexpected server response.'),
    },
  };
}

function setLiveSyncBadge(state, text) {
  const badge = document.getElementById('liveSyncBadge');
  const message = document.getElementById('liveSyncText');
  if (!badge || !message) {
    return;
  }

  const stateMap = {
    pending: 'bg-amber-100 text-amber-800',
    saved: 'bg-emerald-100 text-emerald-800',
    failed: 'bg-rose-100 text-rose-800',
    error: 'bg-rose-100 text-rose-800',
    reset: 'bg-slate-200 text-slate-700',
    idle: 'bg-slate-200 text-slate-700',
  };

  const classes = stateMap[state] || stateMap.idle;
  badge.className = `inline-flex rounded-full px-3 py-1 text-xs font-semibold ${classes}`;
  badge.textContent = state.toUpperCase();
  message.textContent = text;
}

async function pollEnrollmentStatus() {
  try {
    const { data } = await fetchJson('/api/device/enrollment/status');
    if (!data || data.ok === false && !data.pendingEnrollment && !data.lastEnrollmentStatus) {
      setLiveSyncBadge('idle', 'Waiting for enrollment actions...');
      return;
    }

    const pending = data.pendingEnrollment;
    const last = data.lastEnrollmentStatus;

    if (pending) {
      setLiveSyncBadge('pending', `Pending: ${pending.name || 'Student'} (ID ${pending.fingerprintId || '-'}) - waiting for ESP32 scan.`);
      return;
    }

    if (last && last.state) {
      setLiveSyncBadge(String(last.state), String(last.message || 'Latest enrollment status updated.'));
      return;
    }

    setLiveSyncBadge('idle', 'No enrollment in progress.');
  } catch (err) {
    setLiveSyncBadge('error', `Status check failed: ${err.message}`);
  }
}

document.getElementById('classForm')?.addEventListener('submit', async e => {
  e.preventDefault();
  const name = document.getElementById('className').value.trim();
  if (!name) return;
  
  try {
    const res = await fetch('/api/class', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name })
    });
    const data = await res.json();
    if (data.ok) {
      await showNotice('Class Created', `Class "${name}" created successfully.`);
      closeModal('classModal');
      window.location.reload();
    } else {
      await showNotice('Unable To Create Class', data.message || 'Something went wrong.');
    }
  } catch (err) {
    await showNotice('Network Error', err.message);
  }
});

document.getElementById('studentForm')?.addEventListener('submit', async e => {
  e.preventDefault();
  const classId = document.getElementById('studentClassId').value;
  const rollNumber = document.getElementById('studentRoll').value.trim();
  const name = document.getElementById('studentName').value.trim();
  
  if (!classId || !rollNumber || !name) return;
  
  try {
    const { data } = await fetchJson('/students', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ classId, rollNumber, name })
    });

    if (data.ok) {
      const id = data.pendingEnrollment?.fingerprintId || data.fingerprintId || '-';
      await showNotice('Enrollment Started', `Student "${name}" added. Fingerprint ID: ${id}. Ask student to place finger on ESP32 sensor.`);
      closeModal('studentModal');
      await pollEnrollmentStatus();
      window.location.reload();
    } else {
      await showNotice('Unable To Start Enrollment', data.message || 'Request failed.');
    }
  } catch (err) {
    await showNotice('Network Error', err.message);
  }
});

document.getElementById('bulkUploadForm')?.addEventListener('submit', async (e) => {
  e.preventDefault();

  const classId = document.getElementById('bulkUploadClassId').value;
  const fileInput = document.getElementById('bulkUploadFile');
  const statusEl = document.getElementById('bulkUploadStatus');
  const file = fileInput?.files?.[0];

  if (!classId) {
    await showNotice('Missing Class', 'Please open the upload form from a class page first.');
    return;
  }

  if (!file) {
    await showNotice('Missing File', 'Please choose an Excel file first.');
    return;
  }

  if (!/\.xlsx$/i.test(file.name)) {
    await showNotice('Invalid File Type', 'Please upload a .xlsx Excel file.');
    return;
  }

  try {
    if (statusEl) {
      statusEl.textContent = 'Reading workbook and importing students...';
    }

    const buffer = await file.arrayBuffer();
    const workbookBase64 = arrayBufferToBase64(buffer);

    const { data } = await fetchJson(`/class/${classId}/students/bulk-upload`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        classId,
        fileName: file.name,
        workbookBase64,
      }),
    });

    if (!data.ok) {
      if (statusEl) {
        statusEl.textContent = data.message || 'Upload failed.';
      }
      await showNotice('Bulk Upload Failed', data.message || 'Unable to import students.');
      return;
    }

    const skippedCount = Number(data.skippedCount || 0);
    const skippedSummary = skippedCount ? ` Skipped ${skippedCount} row(s).` : '';

    await showNotice(
      'Bulk Upload Complete',
      `${data.message || 'Students imported successfully.'} Created ${data.createdCount || 0} student(s).${skippedSummary}`,
    );

    closeModal('bulkUploadModal');
    window.location.reload();
  } catch (err) {
    if (statusEl) {
      statusEl.textContent = err.message || 'Unexpected upload error.';
    }
    await showNotice('Network Error', err.message || 'Unexpected upload error.');
  }
});

function openStudentModal(classId) {
  document.getElementById('studentClassId').value = classId;
  document.getElementById('studentModal').classList.remove('hidden');
  document.getElementById('studentRoll').focus();
}

async function reenroll(studentId, studentName) {
  const confirmed = await showConfirmDialog({
    title: 'Re-enroll Fingerprint',
    message: `Start fingerprint re-enrollment for ${studentName}? The student must place their finger on ESP32 when prompted.`,
    confirmText: 'Start Re-enroll',
  });
  if (!confirmed) {
    return;
  }

  try {
    const { data } = await fetchJson(`/students/${studentId}/fingerprint/register`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ classId: '<%= activeClassId %>' })
    });

    if (data.ok) {
      await showNotice('Re-enrollment Queued', data.message || 'Enrollment started. Student should place finger on sensor.');
      await pollEnrollmentStatus();
      return;
    }

    await showNotice('Re-enrollment Failed To Start', data.message || 'Unable to queue enrollment request.');
  } catch (err) {
    await showNotice('Network Error', err.message);
  }
}

async function deleteStudent(studentId, studentName) {
  const confirmed = await showConfirmDialog({
    title: 'Delete Student',
    message: `Delete ${studentName}? This removes student record, attendance logs, and queues sensor template deletion.`,
    confirmText: 'Delete Student',
    danger: true,
    requireTriple: true,
  });
  if (!confirmed) {
    return;
  }

  try {
    const { data } = await fetchJson(`/students/${studentId}/delete`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ classId: '<%= activeClassId %>' })
    });

    if (data.ok) {
      await showNotice('Student Deleted', 'Student deleted and sensor template queued for removal.');
      window.location.reload();
      return;
    }

    await showNotice('Delete Failed', data.message || 'Unable to delete student.');
  } catch (err) {
    await showNotice('Network Error', err.message);
  }
}

async function deleteWholeClass(classId, className) {
  const confirmed = await showConfirmDialog({
    title: 'Delete Entire Class',
    message: `Delete class "${className}" with ALL students and attendance data? Sensor deletions will also be queued.`,
    confirmText: 'Delete Class',
    danger: true,
    requireTriple: true,
  });
  if (!confirmed) {
    return;
  }

  try {
    const { data } = await fetchJson(`/class/${classId}/delete-all`, {
      method: 'POST'
    });

    if (data.ok) {
      await showNotice('Class Deleted', `Removed ${data.deletedStudents || 0} students and queued ${data.queuedSensorDeletes || 0} sensor template deletions.`);
      window.location.href = '/';
      return;
    }

    await showNotice('Class Delete Failed', data.message || 'Unable to delete class.');
  } catch (err) {
    await showNotice('Network Error', err.message);
  }
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (currentDialogResolver) {
      currentDialogResolver(false);
      currentDialogResolver = null;
    }
    document.querySelectorAll('[id$="Modal"]').forEach(m => m.classList.add('hidden'));
  }
});

pollEnrollmentStatus();
enrollmentPollTimer = setInterval(pollEnrollmentStatus, 2500);
</script>
