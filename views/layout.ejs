<%- include('./partials/head') %>

<%
  const safePageType = typeof pageType !== 'undefined' ? pageType : '';
  const safeNotice = typeof notice !== 'undefined' ? notice : '';
  const safeError = typeof error !== 'undefined' ? error : '';
%>

<div class="min-h-screen flex flex-col">
  <%- include('partials/topbar') %>

  <div class="flex flex-1 pt-16">
    <%- include('partials/sidebar') %>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto bg-slate-50 xl:ml-72">
      <div class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
        <% if (safeNotice) { %>
          <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800 shadow-sm">✓ <%= safeNotice %></div>
        <% } %>
        <% if (safeError) { %>
          <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800 shadow-sm">✕ <%= safeError %></div>
        <% } %>

        <!-- Dynamic Page Content -->
        <%-include(page || 'class') %>
      </div>
    </main>
  </div>

</div>


  <!-- Global Create Class Modal (available on all pages) -->
  <div id="globalClassModal" class="hidden fixed inset-0 z-50 bg-black/50 p-4">
    <div class="flex min-h-full items-center justify-center">
      <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl">
        <div class="mb-4 flex items-center justify-between">
          <h3 class="text-xl font-bold text-slate-900">Create New Class</h3>
          <button type="button" id="globalClassModalClose" class="rounded-lg border border-slate-300 px-2 py-1 text-sm font-medium text-slate-600 hover:bg-slate-50">x</button>
        </div>
        <form id="globalClassForm" class="space-y-3">
          <label class="block">
            <span class="mb-1 block text-sm font-semibold text-slate-800">Class name</span>
            <input id="globalClassName" name="name" type="text" required placeholder="e.g. BCA A" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-semibold text-slate-800">Session year</span>
            <input id="globalSessionYear" name="sessionYear" type="text" required placeholder="e.g. 2025-2026" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
          </label>
          <button type="submit" class="w-full rounded-lg bg-brand-700 px-3 py-2 text-sm font-bold text-white transition hover:bg-brand-600">Create Class</button>
        </form>
      </div>
    </div>
  </div>

<script>
  (() => {
    const modal = document.getElementById('globalClassModal');
    const closeBtn = document.getElementById('globalClassModalClose');
    const form = document.getElementById('globalClassForm');
    const classNameInput = document.getElementById('globalClassName');

    if (!modal || !form) {
      return;
    }

    function openModal() {
      modal.classList.remove('hidden');
      classNameInput?.focus();
    }

    function closeModal() {
      modal.classList.add('hidden');
    }

    document.querySelectorAll('[data-open-global-class-modal="true"]').forEach((btn) => {
      btn.addEventListener('click', openModal);
    });

    closeBtn?.addEventListener('click', closeModal);

    modal.addEventListener('click', (event) => {
      if (event.target === modal) {
        closeModal();
      }
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);

      try {
        const response = await fetch('/api/classes', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({
            name: String(formData.get('name') || '').trim(),
            sessionYear: String(formData.get('sessionYear') || '').trim(),
          }),
        });

        const data = await response.json();
        if (!response.ok || !data.ok) {
          alert(data.message || 'Unable to create class');
          return;
        }

        form.reset();
        closeModal();
        if (data.class && data.class._id) {
          window.location.href = '/class/' + encodeURIComponent(data.class._id);
          return;
        }
        window.location.reload();
      } catch (error) {
        alert('Failed to create class');
      }
    });
  })();
</script>

<%- include('partials/footer') %>
