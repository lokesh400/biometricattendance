<%- include('partials/head') %>

<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 flex items-center justify-center px-4">
  <div class="w-full max-w-md rounded-3xl border border-slate-200 bg-white p-8 shadow-2xl">
    <div class="mb-6 text-center">
      <div class="mx-auto mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-600 to-indigo-700 text-white shadow-lg">
        <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a5 5 0 0 0-5 5v4H6a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-9a2 2 0 0 0-2-2h-1V6a5 5 0 0 0-5-5Z"/></svg>
      </div>
      <h1 class="text-2xl font-black text-slate-950">Admin Login</h1>
      <p class="mt-2 text-sm text-slate-600">Protected access for class and sensor management.</p>
    </div>

    <% if (error) { %>
      <div class="mb-4 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800"><%= error %></div>
    <% } %>

    <form method="post" action="/login" class="space-y-4">
      <input type="hidden" name="next" value="<%= nextUrl || '/admin' %>">
      <label class="block">
        <span class="mb-1 block text-sm font-semibold text-slate-800">Username</span>
        <input name="username" type="text" required autocomplete="username" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm font-medium text-slate-900 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100" placeholder="admin">
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-semibold text-slate-800">Password</span>
        <input name="password" type="password" required autocomplete="current-password" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm font-medium text-slate-900 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100" placeholder="••••••••">
      </label>
      <button type="submit" class="w-full rounded-xl bg-gradient-to-r from-brand-600 to-brand-700 px-4 py-3 text-sm font-bold text-white shadow-md transition hover:shadow-lg hover:from-brand-500 hover:to-brand-600">Sign In</button>
    </form>

    <p class="mt-5 text-center text-xs text-slate-500">Only authenticated admins can access destructive controls.</p>
  </div>
</div>

<%- include('partials/footer') %>
