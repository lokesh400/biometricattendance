<%- include('./partials/head') %>

<%
  const safeClasses = Array.isArray(classes) ? classes : [];
  const safeActiveClassId = typeof activeClassId !== 'undefined' ? activeClassId : '';
  const firstClassId = safeClasses[0] && safeClasses[0]._id ? String(safeClasses[0]._id) : '';
  const classPath = firstClassId ? '/class/' + firstClassId : '/enrollment';
  const attendancePath = firstClassId ? '/class/' + firstClassId + '/attendance' : '/enrollment';
%>

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50">

  <div class="flex flex-1 pt-16">
    <%- include('partials/sidebar', { pageType: 'home', activeClassId: safeActiveClassId, classes: safeClasses }) %>

    <!-- Main Content -->
    <main class="relative w-full pb-16 xl:ml-72">
    <!-- Hero Section -->
    <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="text-center space-y-6 mb-16">
        <div class="inline-block rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
          ✨ Welcome to Biometric Attendance
        </div>
        
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-slate-950 leading-tight">
          Smart Attendance <span class="bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">Made Simple</span>
        </h2>
        
        <p class="mx-auto max-w-2xl text-lg text-slate-700">
          Streamline your attendance tracking with biometric fingerprint recognition. Fast, accurate, and effortless.
        </p>

        <!-- Quick Stats Row -->
        <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-2xl mx-auto">
          <% if (stats && stats.totalClasses !== undefined) { %>
            <div class="rounded-xl border border-slate-300 bg-white p-4 shadow-sm">
              <div class="text-3xl font-bold text-blue-600"><%= stats.totalClasses %></div>
              <div class="mt-1 text-sm font-medium text-slate-600">Classes</div>
            </div>
            <div class="rounded-xl border border-slate-300 bg-white p-4 shadow-sm">
              <div class="text-3xl font-bold text-indigo-600"><%= stats.totalStudents %></div>
              <div class="mt-1 text-sm font-medium text-slate-600">Students</div>
            </div>
            <div class="rounded-xl border border-slate-300 bg-white p-4 shadow-sm">
              <div class="text-3xl font-bold text-purple-600"><%= stats.todayAttendance %></div>
              <div class="mt-1 text-sm font-medium text-slate-600">Today's Marks</div>
            </div>
          <% } else { %>
            <div class="rounded-xl border border-slate-300 bg-white p-4 shadow-sm">
              <div class="text-3xl font-bold text-blue-600">-</div>
              <div class="mt-1 text-sm font-medium text-slate-600">Classes</div>
            </div>
            <div class="rounded-xl border border-slate-300 bg-white p-4 shadow-sm">
              <div class="text-3xl font-bold text-indigo-600">-</div>
              <div class="mt-1 text-sm font-medium text-slate-600">Students</div>
            </div>
            <div class="rounded-xl border border-slate-300 bg-white p-4 shadow-sm">
              <div class="text-3xl font-bold text-purple-600">-</div>
              <div class="mt-1 text-sm font-medium text-slate-600">Today's Marks</div>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Main Action Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        <!-- Classes & Students Card -->
        <a href="<%= classPath %>" class="group relative rounded-2xl border border-slate-300 bg-gradient-to-br from-white to-slate-50 p-8 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-blue-600/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="text-4xl mb-4">📚</div>
            <h3 class="text-xl font-bold text-slate-950 mb-2">Classes & Students</h3>
            <p class="text-slate-600 text-sm mb-4">Manage classes, add students, and track enrollment status.</p>
            <div class="flex items-center gap-2 text-blue-600 font-semibold text-sm">
              Open Dashboard <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>

        <!-- Attendance Card -->
        <a href="<%= attendancePath %>" class="group relative rounded-2xl border border-slate-300 bg-gradient-to-br from-white to-slate-50 p-8 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 to-indigo-600/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="text-4xl mb-4">✋</div>
            <h3 class="text-xl font-bold text-slate-950 mb-2">Daily Attendance</h3>
            <p class="text-slate-600 text-sm mb-4">View IN/OUT records, track punch times, and attendance summaries.</p>
            <div class="flex items-center gap-2 text-indigo-600 font-semibold text-sm">
              View Attendance <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>

        <!-- Enrollment Card -->
        <a href="/enrollment" class="group relative rounded-2xl border border-slate-300 bg-gradient-to-br from-white to-slate-50 p-8 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-purple-600/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="text-4xl mb-4">👤</div>
            <h3 class="text-xl font-bold text-slate-950 mb-2">Enrollment</h3>
            <p class="text-slate-600 text-sm mb-4">Add new students and capture their fingerprint biometrics.</p>
            <div class="flex items-center gap-2 text-purple-600 font-semibold text-sm">
              Start Enrollment <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>

        <!-- System Admin Card -->
        <a href="/admin" class="group relative rounded-2xl border border-slate-300 bg-gradient-to-br from-white to-slate-50 p-8 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-rose-500/10 to-rose-600/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="text-4xl mb-4">⚙️</div>
            <h3 class="text-xl font-bold text-slate-950 mb-2">System Admin</h3>
            <p class="text-slate-600 text-sm mb-4">Manage sensors, clear databases, and system operations.</p>
            <div class="flex items-center gap-2 text-rose-600 font-semibold text-sm">
              Admin Panel <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>
      </div>

      <!-- Features Section -->
      <section class="rounded-2xl border border-slate-300 bg-white/80 backdrop-blur p-12 mb-16">
        <h3 class="text-2xl font-bold text-slate-950 mb-10 text-center">Key Features</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100">
                <span class="text-xl">🔒</span>
              </div>
            </div>
            <div>
              <h4 class="font-bold text-slate-950 mb-1">Biometric Secure</h4>
              <p class="text-slate-600 text-sm">Fingerprint-based authentication ensures accurate attendance marking.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-100">
                <span class="text-xl">⚡</span>
              </div>
            </div>
            <div>
              <h4 class="font-bold text-slate-950 mb-1">Real-time Updates</h4>
              <p class="text-slate-600 text-sm">Instant punch in/out records with live status updates.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-purple-100">
                <span class="text-xl">📊</span>
              </div>
            </div>
            <div>
              <h4 class="font-bold text-slate-950 mb-1">Detailed Reports</h4>
              <p class="text-slate-600 text-sm">View comprehensive attendance and analytics dashboards.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-rose-100">
                <span class="text-xl">🛠️</span>
              </div>
            </div>
            <div>
              <h4 class="font-bold text-slate-950 mb-1">Easy Management</h4>
              <p class="text-slate-600 text-sm">Intuitive interface for managing classes, students, and enrollments.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-amber-100">
                <span class="text-xl">📱</span>
              </div>
            </div>
            <div>
              <h4 class="font-bold text-slate-950 mb-1">Device Integration</h4>
              <p class="text-slate-600 text-sm">Seamless ESP32 fingerprint sensor connectivity and sync.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-100">
                <span class="text-xl">💾</span>
              </div>
            </div>
            <div>
              <h4 class="font-bold text-slate-950 mb-1">Data Secure</h4>
              <p class="text-slate-600 text-sm">MongoDB-backed storage with robust data backup options.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Quick Start Guide -->
      <section class="rounded-2xl border border-slate-300 bg-gradient-to-br from-blue-50 to-indigo-50 p-12">
        <h3 class="text-2xl font-bold text-slate-950 mb-8 text-center">Getting Started</h3>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="flex flex-col items-center text-center">
            <div class="rounded-full bg-blue-600 text-white font-bold text-lg h-12 w-12 flex items-center justify-center mb-4">1</div>
            <h4 class="font-bold text-slate-950 mb-2">Create Class</h4>
            <p class="text-sm text-slate-600">Start by creating a new class in the Classes section.</p>
          </div>
          <div class="flex flex-col items-center text-center">
            <div class="rounded-full bg-indigo-600 text-white font-bold text-lg h-12 w-12 flex items-center justify-center mb-4">2</div>
            <h4 class="font-bold text-slate-950 mb-2">Enroll Students</h4>
            <p class="text-sm text-slate-600">Add students and capture their fingerprints.</p>
          </div>
          <div class="flex flex-col items-center text-center">
            <div class="rounded-full bg-purple-600 text-white font-bold text-lg h-12 w-12 flex items-center justify-center mb-4">3</div>
            <h4 class="font-bold text-slate-950 mb-2">Enable Device</h4>
            <p class="text-sm text-slate-600">Connect ESP32 sensor and configure network.</p>
          </div>
          <div class="flex flex-col items-center text-center">
            <div class="rounded-full bg-rose-600 text-white font-bold text-lg h-12 w-12 flex items-center justify-center mb-4">4</div>
            <h4 class="font-bold text-slate-950 mb-2">Record Attendance</h4>
            <p class="text-sm text-slate-600">Students scan fingerprints to mark attendance.</p>
          </div>
        </div>
      </section>
    </section>
    </main>
  </div>

<%- include('partials/footer') %>
