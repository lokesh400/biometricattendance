<!-- Attendance & Reporting Page -->

<%
  const filter = attendanceFilter || {};
  const filterMode = filter.mode || 'single';
  const filterDate = filter.date || '';
  const filterFromDate = filter.fromDate || '';
  const filterToDate = filter.toDate || '';
  const periodLabel = filter.periodLabel || 'Today';
%>

<section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-soft">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="inline-flex rounded-xl border border-slate-300 bg-slate-50 p-1">
      <a href="/class/<%= activeClassId %>" class="rounded-lg px-4 py-2 text-sm font-bold text-slate-700 transition hover:bg-white">Students</a>
      <a href="/class/<%= activeClassId %>/attendance" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-bold text-white shadow-sm">Attendance</a>
    </div>
    <span class="inline-flex items-center rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">Period: <%= periodLabel %></span>
  </div>
</section>

<section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
  <div class="mb-4">
    <p class="text-xs font-bold uppercase tracking-widest text-slate-600">Attendance Filters</p>
    <h2 class="mt-1 text-lg font-extrabold text-slate-950">View by Date or Date Range</h2>
  </div>

  <form method="get" action="/class/<%= activeClassId %>/attendance" class="grid gap-4 lg:grid-cols-6">
    <label class="lg:col-span-2 block">
      <span class="mb-1 block text-xs font-bold uppercase tracking-widest text-slate-600">Single Date</span>
      <input type="date" name="date" value="<%= filterDate %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900" />
    </label>
    <label class="lg:col-span-2 block">
      <span class="mb-1 block text-xs font-bold uppercase tracking-widest text-slate-600">From Date (Range)</span>
      <input type="date" name="fromDate" value="<%= filterFromDate %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900" />
    </label>
    <label class="lg:col-span-2 block">
      <span class="mb-1 block text-xs font-bold uppercase tracking-widest text-slate-600">To Date (Range)</span>
      <input type="date" name="toDate" value="<%= filterToDate %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900" />
    </label>
    <div class="lg:col-span-6 flex flex-wrap gap-2">
      <button type="submit" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-bold text-white hover:bg-brand-700">Apply Filter</button>
      <a href="/class/<%= activeClassId %>/attendance" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50">Today</a>
      <span class="self-center text-xs font-medium text-slate-500">Tip: fill only <b>Single Date</b> for one day, or <b>From + To</b> to open the range matrix page.</span>
    </div>
  </form>
</section>

<!-- Stats Cards -->
<section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
  <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
    <p class="text-xs font-bold uppercase tracking-widest text-slate-600">Total Students</p>
    <p class="mt-3 text-4xl font-extrabold text-slate-950"><%= stats.students %></p>
  </article>
  <article class="rounded-2xl border border-emerald-200 bg-emerald-50 p-6 shadow-soft">
    <p class="text-xs font-bold uppercase tracking-widest text-emerald-700">Punch In (<%= filterMode === 'range' ? 'Range' : 'Date' %>)</p>
    <p class="mt-3 text-4xl font-extrabold text-emerald-600"><%= stats.punchIn %></p>
  </article>
  <article class="rounded-2xl border border-rose-200 bg-rose-50 p-6 shadow-soft">
    <p class="text-xs font-bold uppercase tracking-widest text-rose-700">Punch Out (<%= filterMode === 'range' ? 'Range' : 'Date' %>)</p>
    <p class="mt-3 text-4xl font-extrabold text-rose-600"><%= stats.punchOut %></p>
  </article>
  <article class="rounded-2xl border border-blue-200 bg-blue-50 p-6 shadow-soft">
    <p class="text-xs font-bold uppercase tracking-widest text-blue-700">Open Sessions</p>
    <p class="mt-3 text-4xl font-extrabold text-blue-600"><%= stats.activeSessions %></p>
  </article>
</section>

<!-- Daily Summary Table -->
<section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
  <div class="mb-5">
    <p class="text-xs font-bold uppercase tracking-widest text-brand-700">Attendance Summary</p>
    <h2 class="mt-2 text-xl font-extrabold text-slate-950">In/Out Summary with Duration (<%= periodLabel %>)</h2>
  </div>
  
  <div class="overflow-x-auto rounded-xl border border-slate-300">
    <table class="min-w-full text-sm">
      <thead class="bg-gradient-to-r from-slate-50 to-slate-100">
        <tr>
          <th class="px-4 py-3 text-left font-semibold text-slate-700">Roll</th>
          <th class="px-4 py-3 text-left font-semibold text-slate-700">Name</th>
          <th class="px-4 py-3 text-left font-semibold text-slate-700">Punch In</th>
          <th class="px-4 py-3 text-left font-semibold text-slate-700">Punch Out</th>
          <th class="px-4 py-3 text-left font-semibold text-slate-700">Duration</th>
          <th class="px-4 py-3 text-left font-semibold text-slate-700">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% if (attendanceRows && attendanceRows.length) { %>
          <% attendanceRows.forEach((row) => { %>
            <tr class="hover:bg-slate-50 transition">
              <td class="px-4 py-3 font-medium text-slate-900"><%= row.student.rollNumber %></td>
              <td class="px-4 py-3 text-slate-700"><%= row.student.name %></td>
              <td class="px-4 py-3 text-slate-700">
                <% if (row.punchInAt) { %>
                  <span class="inline-flex rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700"><%= new Date(row.punchInAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                <% } else { %>
                  <span class="text-slate-500">-</span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-slate-700">
                <% if (row.punchOutAt) { %>
                  <span class="inline-flex rounded-full bg-rose-100 px-2.5 py-1 text-xs font-semibold text-rose-700"><%= new Date(row.punchOutAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                <% } else { %>
                  <span class="text-slate-500">-</span>
                <% } %>
              </td>
              <td class="px-4 py-3 font-medium text-slate-800">
                <% if (row.onsiteMinutes === null) { %>
                  <span class="text-slate-500">-</span>
                <% } else { %>
                  <span class="inline-flex rounded-full bg-blue-100 px-2.5 py-1 text-xs font-semibold text-blue-700">
                    <%= Math.floor(row.onsiteMinutes / 60) %>h <%= row.onsiteMinutes % 60 %>m
                  </span>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <% if (row.status === 'COMPLETED') { %>
                  <span class="inline-flex rounded-full border border-emerald-300 bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700">✓ Completed</span>
                <% } else if (row.status === 'INSIDE') { %>
                  <span class="inline-flex rounded-full border border-blue-300 bg-blue-50 px-2.5 py-1 text-xs font-semibold text-blue-700">◉ Inside</span>
                <% } else { %>
                  <span class="inline-flex rounded-full border border-slate-300 bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600">○ Absent</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="px-4 py-10 text-center text-slate-500">No students or attendance data found.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>


