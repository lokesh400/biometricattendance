<%
  const safeClasses = Array.isArray(classes) ? classes : [];
  const safeActiveClassId = typeof activeClassId !== 'undefined' && activeClassId ? String(activeClassId) : '';
  const safePageType = typeof pageType !== 'undefined'
    ? String(pageType)
    : (typeof page !== 'undefined' ? String(page) : '');
  const firstClassId = safeClasses[0] && safeClasses[0]._id ? String(safeClasses[0]._id) : '';
  const classIdForActions = safeActiveClassId || firstClassId;
%>

<aside class="fixed left-0 top-0 bottom-0 z-50 hidden w-72 border-r border-slate-300 bg-white xl:block">
  <div class="flex h-full flex-col">
    <div class="border-b border-slate-300 px-4 py-4 text-black">
      <h2 class="mt-1 text-lg font-extrabold">Biometric Attendance</h2>
    </div>

    <div class="flex-1 overflow-y-auto p-4">
      <nav class="space-y-2">
      <a href="/" class="flex items-center gap-3 rounded-xl border px-3 py-2.5 text-sm font-semibold transition <%= safePageType === 'home' ? 'border-brand-400 bg-brand-50 text-brand-800 shadow-sm' : 'border-slate-300 text-slate-700 hover:bg-slate-50' %>">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-slate-100 text-slate-700">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/></svg>
        </span>
        <span>Home</span>
      </a>

      <a href="/enrollment" class="flex items-center gap-3 rounded-xl border px-3 py-2.5 text-sm font-semibold transition <%= safePageType === 'enrollment' ? 'border-brand-400 bg-brand-50 text-brand-800 shadow-sm' : 'border-slate-300 text-slate-700 hover:bg-slate-50' %>">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-slate-100 text-slate-700">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21c1.5-4 4.2-6 8-6s6.5 2 8 6"/></svg>
        </span>
        <span>Enrollment</span>
      </a>

      <a href="/admin" class="flex items-center gap-3 rounded-xl border px-3 py-2.5 text-sm font-semibold transition <%= safePageType === 'admin' ? 'border-brand-400 bg-brand-50 text-brand-800 shadow-sm' : 'border-slate-300 text-slate-700 hover:bg-slate-50' %>">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-slate-100 text-slate-700">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z"/><path d="M3 12h2m14 0h2M12 3v2m0 14v2m6.4-13.4-1.4 1.4M7 17l-1.4 1.4m0-12.8L7 7m10 10 1.4 1.4"/></svg>
        </span>
        <span>System Admin</span>
      </a>
    </nav>

      <div class="mt-4 border-t border-slate-300 pt-4">
      <% if (currentUser) { %>
        <button type="button" data-open-global-class-modal="true" class="w-full rounded-lg bg-gradient-to-r from-brand-600 to-brand-700 px-3 py-2.5 text-sm font-bold text-white shadow-md transition hover:shadow-lg hover:from-brand-500 hover:to-brand-600">
          + Add Class
        </button>
      <% } else { %>
        <a href="/login?next=/admin" class="block w-full rounded-lg bg-gradient-to-r from-brand-600 to-brand-700 px-3 py-2.5 text-center text-sm font-bold text-white shadow-md transition hover:shadow-lg hover:from-brand-500 hover:to-brand-600">Admin Login</a>
      <% } %>
    </div>

      <div class="mt-4 border-t border-slate-300 pt-4 space-y-2">
      <% if (currentUser) { %>
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs font-semibold text-emerald-700">
          Logged in as <%= currentUser.username %>
        </div>
        <a href="/logout" class="block w-full rounded-lg border border-rose-300 bg-rose-50 px-3 py-2.5 text-center text-sm font-bold text-rose-700 transition hover:bg-rose-100">Logout</a>
      <% } else { %>
        <a href="/login" class="block w-full rounded-lg border border-slate-300 bg-slate-50 px-3 py-2.5 text-center text-sm font-bold text-slate-700 transition hover:bg-slate-100">Admin Login</a>
      <% } %>
    </div>

      <div class="mt-4 border-t border-slate-300 pt-4">
        <p class="mb-2 text-xs font-bold uppercase tracking-widest text-slate-600">Classes</p>
        <div class="space-y-2">
        <% if (safeClasses.length) { %>
          <% safeClasses.forEach((cls) => { %>
            <a href="/class/<%= cls._id %>" class="block w-full rounded-xl border px-3 py-2.5 text-left text-sm font-semibold transition <%= String(safeActiveClassId) === String(cls._id) && safePageType !== 'attendance' ? 'border-brand-400 bg-brand-50 text-brand-800 shadow-sm' : 'border-slate-300 text-slate-700 hover:bg-slate-50' %>">
              <div class="flex items-center justify-between gap-2">
                <span class="truncate"><span class="mr-1.5 text-slate-500">#</span><%= cls.name %></span>
                <span class="rounded-full bg-slate-200 px-2 py-0.5 text-xs font-bold text-slate-700"><%= cls.studentCount || 0 %></span>
              </div>
            </a>
          <% }) %>
        <% } else { %>
          <p class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-3 py-3 text-sm font-medium text-slate-600">No classes yet. Start from Enrollment.</p>
        <% } %>
        </div>
      </div>
    </div>
  </div>
</aside>
