<%
  const safeActiveClassName = typeof activeClassName !== 'undefined' && activeClassName ? String(activeClassName) : 'Dashboard';
%>

<header class="fixed left-0 right-0 top-0 z-40 border-b border-slate-300 bg-gradient-to-r from-blue-50 to-indigo-50 backdrop-blur xl:left-72">

  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-4">
      <div class="rounded-lg bg-brand-700 px-3 py-2">
        <p class="text-xs font-bold uppercase tracking-widest text-white">Biometric</p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-600">Attendance System</p>
        <h1 class="text-lg font-extrabold text-slate-950"><%= safeActiveClassName %></h1>
      </div>
    </div>
    <div class="flex items-center gap-3 text-sm text-slate-700">
      <span class="inline-flex items-center rounded-full bg-emerald-100 px-3 py-1 font-semibold text-emerald-700">● Live</span>
      <span class="font-medium"><%= new Date().toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) %></span>
    </div>
  </div>
</header>